{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "NACHA",
  "scopeName": "source.nacha",
  "patterns": [
    {
      "name": "meta.padding.nacha",
      "match": "^9{94}$"
    },
    {
      "name": "invalid.illegal.length.nacha",
      "match": "^.{0,93}$|^.{95,}$"
    },
    {
      "name": "invalid.illegal.record-type.nacha",
      "match": "^[^156789].*$"
    },
    {
      "name": "meta.record.file-header.nacha",
      "match": "^(1)(.{2})(.{10})(.{10})(.{6})(.{4})(.)(.{3})(.{2})(.)(.{23})(.{23})(.{8})$",
      "captures": {
        "1": {
          "name": "keyword.control.record-type.nacha"
        },
        "2": {
          "name": "constant.numeric.priority-code.nacha"
        },
        "3": {
          "name": "variable.other.constant.immediate-destination.nacha"
        },
        "4": {
          "name": "constant.numeric.immediate-origin.nacha"
        },
        "5": {
          "name": "variable.other.constant.file-date.nacha"
        },
        "6": {
          "name": "constant.numeric.file-time.nacha"
        },
        "7": {
          "name": "storage.type.file-id-modifier.nacha"
        },
        "8": {
          "name": "constant.numeric.record-size.nacha"
        },
        "9": {
          "name": "storage.type.blocking-factor.nacha"
        },
        "10": {
          "name": "constant.numeric.format-code.nacha"
        },
        "11": {
          "name": "string.unquoted.institution-name.nacha"
        },
        "12": {
          "name": "entity.name.function.institution-name.nacha"
        },
        "13": {
          "name": "string.unquoted.reference-code.nacha"
        }
      }
    },
    {
      "name": "meta.record.batch-header.nacha",
      "match": "^(5)(.{3})(.{16})(.{20})(.{10})(.{3})(.{10})(.{6})(.{6})(.{3})(.)(.{8})(.{7})$",
      "captures": {
        "1": {
          "name": "keyword.control.record-type.nacha"
        },
        "2": {
          "name": "constant.numeric.service-class-code.nacha"
        },
        "3": {
          "name": "string.unquoted.company-name.nacha"
        },
        "4": {
          "name": "entity.name.function.company-discretionary-data.nacha"
        },
        "5": {
          "name": "string.unquoted.company-identification.nacha"
        },
        "6": {
          "name": "keyword.other.sec-code.nacha"
        },
        "7": {
          "name": "string.unquoted.entry-description.nacha"
        },
        "8": {
          "name": "entity.name.function.company-descriptive-date.nacha"
        },
        "9": {
          "name": "variable.other.constant.effective-date.nacha"
        },
        "10": {
          "name": "constant.numeric.settlement-date.nacha"
        },
        "11": {
          "name": "storage.type.originator-status-code.nacha"
        },
        "12": {
          "name": "constant.numeric.odfi-identification.nacha"
        },
        "13": {
          "name": "storage.type.batch-number.nacha"
        }
      }
    },
    {
      "name": "meta.record.entry-detail.nacha",
      "match": "^(6)(.{2})(.{8})(.)(.{17})(.{10})(.{15})(.{22})(.{2})(.)(.{15})$",
      "captures": {
        "1": {
          "name": "keyword.control.record-type.nacha"
        },
        "2": {
          "name": "constant.numeric.transaction-code.nacha"
        },
        "3": {
          "name": "variable.other.constant.receiving-dfi-identification.nacha"
        },
        "4": {
          "name": "constant.numeric.check-digit.nacha"
        },
        "5": {
          "name": "string.unquoted.account-number.nacha"
        },
        "6": {
          "name": "variable.parameter.amount.nacha"
        },
        "7": {
          "name": "string.unquoted.identification-number.nacha"
        },
        "8": {
          "name": "entity.name.function.receiver-name.nacha"
        },
        "9": {
          "name": "string.unquoted.discretionary-data.nacha"
        },
        "10": {
          "name": "constant.numeric.addenda-indicator.nacha"
        },
        "11": {
          "name": "storage.type.trace-number.nacha"
        }
      }
    },
    {
      "name": "meta.record.addenda.nacha",
      "match": "^(7)(.{2})(.{80})(.{4})(.{7})$",
      "captures": {
        "1": {
          "name": "keyword.control.record-type.nacha"
        },
        "2": {
          "name": "constant.numeric.addenda-type-code.nacha"
        },
        "3": {
          "name": "string.unquoted.addenda-payload.nacha"
        },
        "4": {
          "name": "constant.numeric.addenda-sequence-number.nacha"
        },
        "5": {
          "name": "storage.type.entry-detail-sequence-number.nacha"
        }
      }
    },
    {
      "name": "meta.record.batch-control.nacha",
      "match": "^(8)(.{3})(.{6})(.{10})(.{12})(.{12})(.{10})(.{19})(.{6})(.{8})(.{7})$",
      "captures": {
        "1": {
          "name": "keyword.control.record-type.nacha"
        },
        "2": {
          "name": "constant.numeric.service-class-code.nacha"
        },
        "3": {
          "name": "variable.other.constant.entry-addenda-count.nacha"
        },
        "4": {
          "name": "constant.numeric.entry-hash.nacha"
        },
        "5": {
          "name": "variable.parameter.total-debit.nacha"
        },
        "6": {
          "name": "entity.name.function.total-credit.nacha"
        },
        "7": {
          "name": "string.unquoted.company-id.nacha"
        },
        "8": {
          "name": "variable.parameter.message-authentication-code.nacha"
        },
        "9": {
          "name": "string.unquoted.reserved.nacha"
        },
        "10": {
          "name": "constant.numeric.odfi-identification.nacha"
        },
        "11": {
          "name": "storage.type.batch-number.nacha"
        }
      }
    },
    {
      "name": "meta.record.file-control.nacha",
      "match": "^(9)(.{6})(.{6})(.{8})(.{10})(.{12})(.{12})(.{39})$",
      "captures": {
        "1": {
          "name": "keyword.control.record-type.nacha"
        },
        "2": {
          "name": "constant.numeric.batch-count.nacha"
        },
        "3": {
          "name": "variable.other.constant.block-count.nacha"
        },
        "4": {
          "name": "constant.numeric.entry-addenda-count.nacha"
        },
        "5": {
          "name": "variable.other.constant.entry-hash.nacha"
        },
        "6": {
          "name": "variable.parameter.total-debit.nacha"
        },
        "7": {
          "name": "entity.name.function.total-credit.nacha"
        },
        "8": {
          "name": "string.unquoted.reserved.nacha"
        }
      }
    }
  ]
}